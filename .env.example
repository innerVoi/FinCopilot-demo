# FinCopilot tries the live Agent API when a real API key is configured.
# Keep the placeholder or leave the key unset to use automatic fallback mode.
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=your_base_url_here
OPENAI_MODEL=gpt-5.4-mini

# Agent API is attempted by default; if the live Agent is unavailable, the app falls back automatically.
ENABLE_AGENT_API=true
OPENAI_AGENT_MODEL=gpt-5.4-mini

# V2.3: Memory database
FINCOPILOT_MEMORY_DB_PATH=data/fincopilot_memory.db
FINCOPILOT_DEFAULT_USER_ID=demo_user
FINCOPILOT_DEFAULT_WORKSPACE_ID=demo_workspace
